# --- Database ---
POSTGRES_USER=jobhunter
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jobhunter
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://jobhunter:changeme@postgres:5432/jobhunter
SYNC_DATABASE_URL=postgresql+psycopg://jobhunter:changeme@postgres:5432/jobhunter

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
TIMEZONE=Africa/Cairo
DAILY_RUN_HOUR=0
DAILY_RUN_MINUTE=0

# --- Anthropic (optional; AI features no-op if unset) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_ENABLED=true
AI_MAX_JOBS_PER_RUN=80

# --- Scraping ---
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=4
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
WELLFOUND_ENABLED=false
PLAYWRIGHT_HEADLESS=true

# --- Catchup ---
# If last successful daily run was older than this many hours, run catchup on startup.
CATCHUP_THRESHOLD_HOURS=20

# --- Resume snippet (used by AI tailor; keep short) ---
RESUME_SUMMARY=Java backend developer (Spring Boot, Hibernate, JWT, Redis, Kafka, Keycloak, Stripe). CS student at Menofia University 2022-2026. Built Poly-Clinic microservices (Kafka outbox, Redis distributed locks), E-Commerce REST API, Gitlet VCS, JavaFX PathFinder. Codeforces Pupil. Strong DSA.
