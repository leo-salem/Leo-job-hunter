# --- Database ---
POSTGRES_USER=jobhunter
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jobhunter
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://jobhunter:changeme@postgres:5432/jobhunter
SYNC_DATABASE_URL=postgresql+psycopg://jobhunter:changeme@postgres:5432/jobhunter

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
TIMEZONE=Africa/Cairo
DAILY_RUN_HOUR=0
DAILY_RUN_MINUTE=0

# --- Scraping ---
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=4
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
WELLFOUND_ENABLED=false
PLAYWRIGHT_HEADLESS=true

# --- Catchup ---
# If last successful daily run was older than this many hours, run catchup on startup.
CATCHUP_THRESHOLD_HOURS=20

# --- Concurrency ---
# Global cap: total companies processed in parallel during a scrape.
# Each company has its own HTTP client and DB session.
DAILY_CONCURRENCY=4

# Per-source caps. These LAYER ON TOP of DAILY_CONCURRENCY so that even if 4
# global slots are free, at most N of them can go to the same source. This is
# what protects you from rate-limits — even if you raise DAILY_CONCURRENCY to
# 10, only 1 LinkedIn search runs at a time.
# Greenhouse / Lever / Ashby have no per-source cap (stable JSON APIs).
LINKEDIN_CONCURRENCY=1   # LinkedIn guest endpoint = most aggressively rate-limited
WUZZUF_CONCURRENCY=2
BAYT_CONCURRENCY=2
WORKDAY_CONCURRENCY=2
WELLFOUND_CONCURRENCY=1
